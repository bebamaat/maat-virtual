{
  "name": "maat-virtual-painel",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "sync-docs": "mkdir -p public/docs && (cp ../docs/maat-virtual/*.md public/docs/ 2>/dev/null || true)",
    "validate:organograma": "node scripts/validate-organograma.mjs",
    "predev": "npm run sync-docs",
    "prebuild": "npm run sync-docs && npm run validate:organograma",
    "dev": "next dev",
    "build": "next build",
    "start": "next start"
  },
  "dependencies": {
    "@vercel/kv": "^3.0.0",
    "next": "^14.2.0",
    "next-auth": "^4.24.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  }
}
